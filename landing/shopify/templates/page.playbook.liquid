.hero-seelink{color:var(--tx-62);border-bottom:1px solid var(--line-12);}
@media(max-width:640px){ .price-now{font-size:54px;} .hero-cta-main{max-width:none;} .av-stack .av{width:38px;height:38px;font-size:12px;} }
