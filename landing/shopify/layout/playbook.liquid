<!doctype html>
<html lang="pt-BR">
<head>
{{ content_for_header }}
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Playbook IA na Prática — 5 Agentes Prontos para Negócios | LEVVL Labs</title>
<meta name="description" content="Implemente 5 Agentes de IA no seu negócio mesmo sem saber programar. Playbook prático com arquiteturas prontas, prompts base, fluxos, canvas, templates e passo a passo.">
<meta property="og:title" content="Playbook IA na Prática — 5 Agentes Prontos para Negócios">
<meta property="og:description" content="Do ChatGPT improvisado a agentes de IA estruturados. 5 arquiteturas prontas para aplicar em atendimento, vendas, marketing, operações e dados.">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Outfit:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ===================================================================
   PLAYBOOK IA NA PRÁTICA — Landing · LEVVL Labs Design System
   =================================================================== */
:root{
  --canvas:#08080C; --bg:#0A0A0F; --s1:#0E0E15; --s2:#13131A; --s3:#1A1A24;
  --purple:#6C5CE7; --cyan:#00F5D4; --accent:#00F5D4;
  --grad:linear-gradient(135deg,#6C5CE7,#00F5D4);
  --amber:#FFA502; --error:#FF4757; --info:#5B8DEF; --accent2:#B26CF0;
  --tx:#fff; --tx-70:rgba(255,255,255,.70); --tx-62:rgba(255,255,255,.62);
  --tx-55:rgba(255,255,255,.55); --tx-45:rgba(255,255,255,.45); --tx-35:rgba(255,255,255,.35);
  --line:rgba(255,255,255,.08); --line-12:rgba(255,255,255,.12);
  --f-title:'Space Grotesk',sans-serif; --f-body:'Outfit',sans-serif; --f-mono:'JetBrains Mono',monospace;
  --glow-p:0 0 24px rgba(108,92,231,.35); --glow-c:0 0 24px rgba(0,245,212,.30);
  --wrap:1200px;
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{margin:0;background:var(--canvas);color:var(--tx);font-family:var(--f-body);font-weight:400;
  -webkit-font-smoothing:antialiased;overflow-x:hidden;line-height:1.6;}
::selection{background:rgba(108,92,231,.35);color:#fff;}
img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}

/* ambient bg */
body::before{content:"";position:fixed;inset:0;z-index:-2;
  background-image:radial-gradient(circle, rgba(108,92,231,0.07) 1px, transparent 1px);background-size:30px 30px;}
body::after{content:"";position:fixed;top:-280px;left:50%;transform:translateX(-50%);width:1100px;height:700px;z-index:-2;
  background:radial-gradient(ellipse at center, rgba(108,92,231,0.18), transparent 68%);filter:blur(40px);pointer-events:none;}

.wrap{max-width:var(--wrap);margin:0 auto;padding:0 24px;}
.sec{padding:88px 0;position:relative;}
.sec--tight{padding:60px 0;}

/* ---------- typography ---------- */
.kicker{font-family:var(--f-mono);font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--purple);margin:0 0 16px;display:flex;align-items:center;gap:8px;}
.kicker .ar{color:var(--cyan);}
h1,h2,h3{font-family:var(--f-title);letter-spacing:-1px;line-height:1.05;margin:0;}
.h-hero{font-weight:700;font-size:clamp(38px,5.4vw,66px);letter-spacing:-2px;line-height:1.02;}
.h-sec{font-weight:700;font-size:clamp(28px,3.6vw,44px);letter-spacing:-1.5px;line-height:1.08;margin:0 0 18px;max-width:20ch;}
.h-sec.center{margin-left:auto;margin-right:auto;text-align:center;}
.h3{font-family:var(--f-title);font-weight:600;font-size:19px;letter-spacing:-.3px;}
.grad{color:var(--cyan);}   /* robusto: cor sólida, nunca background-clip:text */
.lead{font-size:clamp(16px,1.7vw,19px);line-height:1.6;color:var(--tx-62);font-weight:300;}
.lead.center{text-align:center;margin-left:auto;margin-right:auto;max-width:62ch;}
p{margin:0 0 14px;color:var(--tx-70);font-weight:300;}
strong{color:#fff;font-weight:600;}
.mono{font-family:var(--f-mono);}
.eyebrow{font-family:var(--f-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--tx-45);}
.center{text-align:center;}

/* ---------- buttons ---------- */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:9px;font-family:var(--f-title);font-weight:700;
  font-size:16px;border-radius:999px;padding:15px 28px;border:none;cursor:pointer;transition:transform .2s cubic-bezier(.2,.7,.3,1),box-shadow .2s;text-align:center;}
.btn--primary{color:#07070B;background:var(--grad);box-shadow:inset 0 1px 0 rgba(255,255,255,.32),0 0 26px rgba(0,245,212,.22);}
.btn--primary:hover{transform:translateY(-2px);box-shadow:inset 0 1px 0 rgba(255,255,255,.32),0 0 40px rgba(0,245,212,.4);}
.btn--ghost{color:#fff;background:transparent;border:1px solid var(--line-12);}
.btn--ghost:hover{border-color:var(--purple);box-shadow:var(--glow-p);}
.btn--lg{font-size:17px;padding:17px 34px;}
.btn--sm{font-size:13px;padding:10px 18px;}

/* ---------- header ---------- */
.hdr{position:sticky;top:0;z-index:100;backdrop-filter:blur(14px);background:rgba(8,8,12,.72);border-bottom:1px solid var(--line);}
.hdr-in{display:flex;align-items:center;justify-content:space-between;height:66px;}
.lockup{display:flex;align-items:center;gap:11px;}
.wordmark{font-family:var(--f-title);font-weight:700;letter-spacing:4px;font-size:19px;}
.pill-labs{font-family:var(--f-mono);font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--tx-55);border:1px solid var(--line-12);border-radius:999px;padding:4px 10px;}
.nav{display:flex;align-items:center;gap:26px;}
.nav a{font-size:14px;color:var(--tx-62);font-weight:400;transition:color .2s;}
.nav a:hover{color:#fff;}
.hdr .btn{padding:11px 20px;font-size:14px;}

/* ---------- badges / pills / tags ---------- */
.badge{display:inline-flex;align-items:center;gap:8px;font-family:var(--f-mono);font-size:12px;letter-spacing:1.5px;text-transform:uppercase;
  color:var(--cyan);background:rgba(0,245,212,.08);border:1px solid rgba(0,245,212,.35);border-radius:999px;padding:8px 15px;}
.badge .dot{width:7px;height:7px;border-radius:50%;background:var(--cyan);box-shadow:0 0 8px var(--cyan);}
.tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--f-mono);font-size:11px;letter-spacing:1px;color:var(--tx-62);
  background:rgba(255,255,255,.04);border:1px solid var(--line-12);border-radius:999px;padding:5px 12px;}
.tag--p{color:var(--purple);border-color:rgba(108,92,231,.4);background:rgba(108,92,231,.1);}
.tag--c{color:var(--cyan);border-color:rgba(0,245,212,.35);background:rgba(0,245,212,.08);}
.tag--easy{color:var(--cyan);border-color:rgba(0,245,212,.3);}
.tag--mid{color:var(--amber);border-color:rgba(255,165,2,.35);background:rgba(255,165,2,.08);}
.tags{display:flex;flex-wrap:wrap;gap:9px;}

/* ---------- cards / grid ---------- */
.card{background:var(--s1);border:1px solid var(--line);border-radius:16px;padding:26px;transition:transform .25s cubic-bezier(.2,.7,.3,1),border-color .25s,box-shadow .25s;}
.card--hover:hover{transform:translateY(-3px);border-color:rgba(108,92,231,.45);box-shadow:0 0 30px rgba(108,92,231,.12);}
.card--2{background:var(--s2);}
.grid{display:grid;gap:18px;}
.g2{grid-template-columns:repeat(2,1fr);}
.g3{grid-template-columns:repeat(3,1fr);}
.g4{grid-template-columns:repeat(4,1fr);}
.g5{grid-template-columns:repeat(5,1fr);}
.card-ico{width:44px;height:44px;border-radius:12px;background:rgba(108,92,231,.14);border:1px solid rgba(108,92,231,.3);
  display:flex;align-items:center;justify-content:center;margin-bottom:16px;}
.card-ico svg{width:22px;height:22px;}
.card-ico--c{background:rgba(0,245,212,.12);border-color:rgba(0,245,212,.3);}
.card h3,.card .h3{margin:0 0 8px;}
.card p{font-size:14px;margin:0;line-height:1.55;}
.hl{color:var(--purple);} .hl-c{color:var(--cyan);}

/* section head */
.sec-head{max-width:760px;margin:0 0 44px;}
.sec-head.center{margin-left:auto;margin-right:auto;text-align:center;}

/* checks / lists */
.ul{list-style:none;padding:0;margin:0;}
.ul li{position:relative;padding-left:28px;font-size:15px;line-height:1.5;color:var(--tx-70);font-weight:300;margin-bottom:12px;}
.ul li::before{content:"✓";position:absolute;left:2px;top:0;color:var(--cyan);font-weight:700;}
.ul--x li::before{content:"✕";color:var(--error);}

/* eyebrow flow chip row (trigger->agent->action) */
.flowrow{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.fchip{display:inline-flex;align-items:center;gap:9px;font-family:var(--f-mono);font-size:12px;letter-spacing:1px;
  border:1px solid var(--line-12);border-radius:12px;padding:12px 16px;background:var(--s2);}
.fchip--t{border-color:rgba(0,245,212,.4);color:var(--cyan);}
.fchip--a{border-color:rgba(108,92,231,.5);color:#fff;box-shadow:var(--glow-p);}
.fchip--x{border-color:rgba(108,92,231,.4);color:var(--purple);}
.farrow{color:var(--purple);font-weight:700;}

/* ---------- reveal on scroll ---------- */
.rv{opacity:0;transform:translateY(22px);transition:opacity .7s cubic-bezier(.2,.7,.3,1),transform .7s cubic-bezier(.2,.7,.3,1);}
.rv.in{opacity:1;transform:none;}

/* ===================================================================
   HERO
   =================================================================== */
.hero{position:relative;padding:56px 0 40px;overflow:hidden;}
.hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:48px;align-items:center;}
.hero h1{margin:0 0 22px;max-width:16ch;}
.hero .sub{font-size:clamp(15px,1.7vw,18px);color:var(--tx-62);font-weight:300;max-width:52ch;margin:0 0 28px;line-height:1.6;}
.hero-cta{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:18px;}
.hero-micro{font-family:var(--f-mono);font-size:12px;letter-spacing:.5px;color:var(--tx-45);margin-bottom:26px;}
.hero-micro b{color:var(--cyan);font-weight:500;}
.vbadges{display:flex;flex-wrap:wrap;gap:10px;}
.vbadge{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--tx-70);font-weight:400;
  background:var(--s1);border:1px solid var(--line);border-radius:999px;padding:8px 14px;}
.vbadge svg{width:15px;height:15px;color:var(--cyan);}
/* hero · prova social + desconto */
.hero-proof{display:flex;align-items:center;gap:14px;margin-bottom:28px;}
.av-stack{display:flex;}
.av-stack img{width:44px;height:44px;border-radius:50%;object-fit:cover;border:2px solid var(--canvas);margin-left:-13px;box-shadow:0 0 0 1px rgba(255,255,255,.1);}
.av-stack img:first-child{margin-left:0;}
.hero-proof .stars{color:#FFB020;font-size:16px;letter-spacing:2px;line-height:1;}
.hero-proof .stars b{color:#fff;font-family:var(--f-title);font-weight:700;margin-left:7px;font-size:15px;letter-spacing:0;}
.hero-proof .pl{font-size:12.5px;color:var(--tx-55);display:block;margin-top:5px;}
.hero-offer{display:flex;align-items:center;gap:22px;flex-wrap:wrap;margin:0 0 16px;}
.hero-price{display:flex;align-items:baseline;gap:11px;}
.hp-off{font-family:var(--f-mono);font-size:12px;font-weight:600;letter-spacing:1px;color:#07070B;background:var(--grad);border-radius:8px;padding:6px 9px;align-self:center;box-shadow:0 0 18px rgba(0,245,212,.3);}
.hp-old{font-size:18px;color:var(--tx-45);text-decoration:line-through;font-weight:500;font-family:var(--f-title);}
.hp-now{font-family:var(--f-title);font-weight:700;font-size:42px;letter-spacing:-1.5px;line-height:1;}
.hero-trust{font-family:var(--f-mono);font-size:12px;color:var(--tx-45);letter-spacing:.5px;}
.hero-trust .sep{color:var(--cyan);}
.hero-seelink{color:var(--tx-62);border-bottom:1px solid var(--line-12);padding-bottom:1px;}
@media (max-width:640px){ .hero-offer{gap:16px;} .av-stack img{width:40px;height:40px;} }
/* headline com palavras coloridas (gradiente aproximado, robusto) */
.w1{color:#7B6CF0;} .w2{color:#4CA9E8;} .w3{color:#00F5D4;}
/* card de preço com destaque */
.hero-offer{flex-direction:column;align-items:flex-start;}
.price-card{display:inline-flex;align-items:center;gap:18px;background:linear-gradient(135deg,rgba(108,92,231,.14),rgba(0,245,212,.09));border:1px solid rgba(0,245,212,.4);border-radius:16px;padding:16px 22px;box-shadow:0 0 44px rgba(0,245,212,.18);}
.hp-off{font-size:15px;padding:9px 12px;letter-spacing:0;align-self:center;}
.price-line{display:flex;align-items:baseline;gap:12px;}
.hp-now{font-size:52px;}
.hp-sub{font-family:var(--f-mono);font-size:12px;color:var(--tx-55);margin-top:3px;letter-spacing:.3px;}
.hp-sub b{color:var(--cyan);font-weight:600;}
.hero-cta-main{width:100%;max-width:440px;font-size:18px;padding:19px 32px;}
@media (max-width:640px){ .price-card{width:100%;} .hp-now{font-size:44px;} .hero-cta-main{max-width:none;} }

/* 3D cover mockup */
.stage{position:relative;perspective:1400px;min-height:520px;display:flex;align-items:center;justify-content:center;}
.book{position:relative;width:300px;transform:rotateY(-20deg) rotateX(4deg);transform-style:preserve-3d;
  filter:drop-shadow(0 40px 60px rgba(0,0,0,.6));animation:float 6s ease-in-out infinite;}
.book img{width:100%;border-radius:6px 10px 10px 6px;border:1px solid rgba(255,255,255,.1);}
.book::before{content:"";position:absolute;left:-14px;top:2px;bottom:2px;width:14px;transform:translateZ(-6px) rotateY(0);
  background:linear-gradient(180deg,#1a1a24,#0a0a0f);border-radius:4px 0 0 4px;box-shadow:inset -2px 0 6px rgba(0,0,0,.6);}
.book::after{content:"";position:absolute;inset:0;border-radius:6px 10px 10px 6px;
  background:linear-gradient(115deg,rgba(255,255,255,.14),transparent 42%);pointer-events:none;}
.book-glow{position:absolute;width:360px;height:360px;border-radius:50%;
  background:radial-gradient(circle,rgba(0,245,212,.18),transparent 66%);filter:blur(20px);z-index:-1;}
@keyframes float{0%,100%{transform:rotateY(-20deg) rotateX(4deg) translateY(0);}50%{transform:rotateY(-20deg) rotateX(4deg) translateY(-14px);}}
/* floating agent chips around book */
.fcard{position:absolute;background:rgba(19,19,26,.92);border:1px solid var(--line-12);border-radius:12px;padding:10px 13px;
  display:flex;align-items:center;gap:9px;font-size:12px;backdrop-filter:blur(6px);box-shadow:0 12px 30px rgba(0,0,0,.5);animation:float 7s ease-in-out infinite;}
.fcard .fi{width:26px;height:26px;border-radius:7px;display:flex;align-items:center;justify-content:center;background:rgba(108,92,231,.16);}
.fcard .fi svg{width:15px;height:15px;color:var(--cyan);}
.fcard b{font-family:var(--f-title);font-weight:600;font-size:12.5px;color:#fff;}
.fcard span{font-family:var(--f-mono);font-size:10px;color:var(--tx-45);}
.fc1{top:24px;left:-6px;animation-delay:.4s;} .fc2{top:150px;right:-18px;animation-delay:1.1s;}
.fc3{bottom:40px;left:-24px;animation-delay:.7s;}
.stage-tag{position:absolute;bottom:-4px;right:12px;}

/* ===================================================================
   CREDIBILITY BAR
   =================================================================== */
.credbar{border-top:1px solid var(--line);border-bottom:1px solid var(--line);background:rgba(14,14,21,.5);}
.cred-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:0;}
.cred{display:flex;align-items:center;gap:12px;padding:22px 20px;border-right:1px solid var(--line);}
.cred:last-child{border-right:none;}
.cred svg{width:22px;height:22px;color:var(--cyan);flex:none;}
.cred span{font-size:13.5px;color:var(--tx-70);line-height:1.35;font-weight:400;}

/* ===================================================================
   SCROLL CLIPS
   =================================================================== */
.clip-frame{position:relative;border-radius:18px;padding:1.5px;background:linear-gradient(135deg,rgba(108,92,231,.5),rgba(0,245,212,.4));
  box-shadow:0 20px 50px rgba(0,0,0,.5);}
.clip-inner{background:var(--canvas);border-radius:17px;overflow:hidden;height:420px;position:relative;}
.clip-strip{display:flex;flex-direction:column;gap:10px;padding:10px;animation:clipscroll 20s linear infinite alternate;}
.clip-strip img{border-radius:6px;border:1px solid var(--line);}
@keyframes clipscroll{from{transform:translateY(0);}to{transform:translateY(calc(-100% + 400px));}}
.clip-frame:hover .clip-strip{animation-play-state:paused;}
.clip-cap{position:absolute;left:0;right:0;bottom:0;padding:16px 18px;z-index:2;
  background:linear-gradient(180deg,transparent,rgba(8,8,12,.96) 55%);}
.clip-cap b{font-family:var(--f-title);font-weight:600;font-size:15px;display:block;margin-bottom:3px;}
.clip-cap span{font-size:12.5px;color:var(--tx-55);}
.clip-tag{position:absolute;top:12px;left:12px;z-index:2;}

/* ===================================================================
   METHOD TIMELINE
   =================================================================== */
.timeline{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;position:relative;}
.tl-line{position:absolute;top:26px;left:5%;right:5%;height:2px;background:linear-gradient(90deg,var(--purple),var(--cyan));opacity:.5;z-index:0;}
.tl-step{position:relative;z-index:1;}
.tl-dot{width:52px;height:52px;border-radius:14px;background:var(--s2);border:1px solid rgba(108,92,231,.5);
  display:flex;align-items:center;justify-content:center;font-family:var(--f-title);font-weight:700;font-size:22px;color:var(--cyan);margin-bottom:16px;box-shadow:var(--glow-p);}
.tl-step h3{font-size:15px;margin:0 0 6px;}
.tl-step p{font-size:12.5px;line-height:1.5;margin:0;}

/* ===================================================================
   COMPARISON
   =================================================================== */
.cmp{border:1px solid var(--line);border-radius:18px;overflow:hidden;}
.cmp-head{display:grid;grid-template-columns:1fr 1fr;}
.cmp-head>div{padding:20px 24px;font-family:var(--f-title);font-weight:600;font-size:16px;}
.cmp-head .bad{background:rgba(255,71,87,.06);color:var(--tx-70);border-bottom:1px solid var(--line);}
.cmp-head .good{background:rgba(0,245,212,.07);color:var(--cyan);border-bottom:1px solid var(--line);border-left:1px solid var(--line);}
.cmp-row{display:grid;grid-template-columns:1fr 1fr;border-top:1px solid var(--line);}
.cmp-row>div{padding:16px 24px;font-size:14px;display:flex;align-items:center;gap:10px;}
.cmp-row .good{border-left:1px solid var(--line);color:#fff;}
.cmp-row .bad{color:var(--tx-55);}
.cmp-row .good::before{content:"✓";color:var(--cyan);font-weight:700;}
.cmp-row .bad::before{content:"✕";color:var(--error);font-weight:700;}
.cmp-block-label{display:none;}

/* ===================================================================
   OFFER
   =================================================================== */
.offer{border-radius:22px;padding:2px;background:linear-gradient(135deg,#6C5CE7,#00F5D4);box-shadow:0 0 60px rgba(108,92,231,.25);}
.offer-in{background:var(--s1);border-radius:20px;padding:44px;display:grid;grid-template-columns:1.2fr 1fr;gap:40px;align-items:center;}
.price{font-family:var(--f-title);}
.price .old{font-size:18px;color:var(--tx-45);text-decoration:line-through;font-weight:500;}
.price .now{font-size:56px;font-weight:700;letter-spacing:-2px;line-height:1;}
.price .now small{font-size:22px;color:var(--tx-55);}
.price .edit{font-family:var(--f-mono);font-size:11px;color:var(--amber);letter-spacing:1px;}
.plabel{font-family:var(--f-mono);font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--cyan);margin-bottom:10px;}

/* ---------- FAQ ---------- */
.faq{max-width:820px;margin:0 auto;}
.faq details{border:1px solid var(--line);border-radius:14px;background:var(--s1);margin-bottom:12px;overflow:hidden;}
.faq summary{list-style:none;cursor:pointer;padding:20px 24px;font-family:var(--f-title);font-weight:600;font-size:16px;
  display:flex;justify-content:space-between;align-items:center;gap:16px;}
.faq summary::-webkit-details-marker{display:none;}
.faq summary::after{content:"+";font-size:24px;color:var(--purple);font-weight:400;transition:transform .2s;flex:none;}
.faq details[open] summary::after{transform:rotate(45deg);}
.faq .fa{padding:0 24px 22px;color:var(--tx-62);font-size:14.5px;line-height:1.6;font-weight:300;}

/* ---------- guarantee ---------- */
.guarantee{display:grid;grid-template-columns:auto 1fr;gap:28px;align-items:center;background:var(--s1);border:1px solid rgba(0,245,212,.25);border-radius:18px;padding:34px;}
.seal{width:110px;height:110px;border-radius:50%;border:2px solid rgba(0,245,212,.4);display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:radial-gradient(circle,rgba(0,245,212,.08),transparent);box-shadow:var(--glow-c);flex:none;}
.seal b{font-family:var(--f-title);font-weight:700;font-size:26px;color:var(--cyan);line-height:1;}
.seal span{font-family:var(--f-mono);font-size:9px;letter-spacing:1px;color:var(--tx-55);text-transform:uppercase;margin-top:4px;}

/* ---------- placeholder marker ---------- */
.ph{color:var(--amber);font-family:var(--f-mono);font-size:.9em;}

/* ---------- footer ---------- */
.ftr{border-top:1px solid var(--line);padding:48px 0 36px;margin-top:40px;}
.ftr-grid{display:flex;justify-content:space-between;gap:30px;flex-wrap:wrap;align-items:flex-start;}
.ftr p{font-size:13px;color:var(--tx-45);max-width:40ch;}
.ftr a{color:var(--tx-55);font-size:13px;}
.ftr-links{display:flex;flex-direction:column;gap:9px;}
.ftr-note{margin-top:26px;padding-top:20px;border-top:1px solid var(--line);font-family:var(--f-mono);font-size:11px;color:var(--tx-35);letter-spacing:.5px;}

/* ===================================================================
   RESPONSIVE
   =================================================================== */
@media (max-width:980px){
  .hero-grid{grid-template-columns:1fr;gap:20px;}
  .stage{min-height:440px;order:2;}
  .g3,.g4,.g5{grid-template-columns:repeat(2,1fr);}
  .timeline{grid-template-columns:repeat(3,1fr);row-gap:26px;}
  .tl-line{display:none;}
  .offer-in{grid-template-columns:1fr;gap:28px;text-align:center;}
  .offer-in .btn{width:100%;}
  .cred-grid{grid-template-columns:repeat(2,1fr);}
  .cred{border-bottom:1px solid var(--line);}
  .nav{display:none;}
}
@media (max-width:640px){
  .sec{padding:60px 0;}
  .wrap{padding:0 18px;}
  .g2,.g3,.g4,.g5{grid-template-columns:1fr;}
  .timeline{grid-template-columns:1fr;}
  .hero-cta{flex-direction:column;}
  .hero-cta .btn{width:100%;}
  .btn{width:100%;}
  .hdr .btn{width:auto;}
  .book{width:230px;}
  .cred-grid{grid-template-columns:1fr;}
  .cred{border-right:none;}
  /* comparison -> stacked blocks */
  .cmp-head{display:none;}
  .cmp{border:none;border-radius:0;overflow:visible;}
  .cmp-row{grid-template-columns:1fr;border:1px solid var(--line);border-radius:14px;margin-bottom:12px;overflow:hidden;}
  .cmp-row>div{border-left:none!important;}
  .cmp-row .bad{background:rgba(255,71,87,.04);border-bottom:1px solid var(--line);}
  .cmp-row .good{background:rgba(0,245,212,.05);}
  .cmp-block-label{display:inline;font-family:var(--f-mono);font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--tx-45);margin-right:6px;}
  .price .now{font-size:46px;}
  .offer{border-radius:18px;} .offer-in{padding:28px 22px;}
  .guarantee{grid-template-columns:1fr;text-align:center;justify-items:center;}
  .clip-inner{height:360px;}
  @keyframes clipscroll{from{transform:translateY(0);}to{transform:translateY(calc(-100% + 340px));}}
}
@media (prefers-reduced-motion: reduce){
  .clip-strip{animation:none;} .book,.fcard{animation:none;}
  .rv{opacity:1;transform:none;transition:none;}
  html{scroll-behavior:auto;}
}
</style>
